# Gemini API 키를 입력합니다.
GOOGLE_API_KEY=여기에_본인_GOOGLE_API_KEY_입력

# OpenAI API 키를 입력합니다.
OPENAI_API_KEY=여기에_본인_OPENAI_API_KEY_입력

# Gemini 실습에 사용할 모델명입니다.
GEMINI_MODEL=gemini-2.5-flash

# Gemini 임베딩 모델명입니다.
GEMINI_EMBED_MODEL=models/gemini-embedding-001

# OpenAI 실습에 사용할 모델명입니다.
OPENAI_MODEL=gpt-4o-mini
