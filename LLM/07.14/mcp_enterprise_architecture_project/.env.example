APP_HOST=127.0.0.1
APP_PORT=8000

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# false이면 GitHub, Slack, Email이 데모 모드로 실행됩니다.
LIVE_MODE=false

# GitHub live 모드
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Slack live 모드
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# SMTP Email live 모드
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Browser Tool 허용 호스트
BROWSER_ALLOWED_HOSTS=example.com,docs.python.org,modelcontextprotocol.io
