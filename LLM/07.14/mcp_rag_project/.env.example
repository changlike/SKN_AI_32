# FastAPI 서버 설정
APP_HOST=127.0.0.1
APP_PORT=8000

# OpenAI 설정
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# local 또는 openai
EMBEDDING_BACKEND=local

# faiss 또는 qdrant
VECTOR_BACKEND=faiss

# Qdrant를 사용할 경우 local 또는 server
QDRANT_MODE=local
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=mcp_rag_documents

# MySQL 설정
MYSQL_ENABLED=false
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=mcp_rag_db
MYSQL_USER=mcp_user
MYSQL_PASSWORD=1234

# RAG 설정
RAG_TOP_K=4
CHUNK_SIZE=700
CHUNK_OVERLAP=100
LOCAL_EMBEDDING_DIMENSION=384
