# LLM provider: gemini 또는 openai
LLM_PROVIDER=gemini
GOOGLE_API_KEY=여기에_Google_API_KEY_입력
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-001
OPENAI_API_KEY=여기에_OpenAI_API_KEY_입력
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=multi_agent_db
MYSQL_USER=multi_agent_user
MYSQL_PASSWORD=multi_agent_password
DATABASE_URL=mysql+pymysql://multi_agent_user:multi_agent_password@127.0.0.1:3306/multi_agent_db?charset=utf8mb4

# Vector DB / MCP
CHROMA_PATH=./chroma_data
MCP_SERVER_COMMAND=python
MCP_SERVER_ARGS=-m,mcp_server.server
