# OpenAI API Key를 입력합니다.
# 예: OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
OPENAI_API_KEY=

# OpenAI 모델명을 입력합니다.
# gpt-5.5 계열은 temperature/top_p를 지원하지 않을 수 있으므로 코드에서 자동 분기합니다.
OPENAI_MODEL=gpt-5.5

# 일반 모델에서 사용할 temperature 기본값입니다.
OPENAI_TEMPERATURE=0.7

# 일반 모델에서 사용할 top_p 기본값입니다.
OPENAI_TOP_P=0.95

# 응답 최대 토큰 수 기본값입니다.
OPENAI_MAX_OUTPUT_TOKENS=900

# FastAPI 앱 제목입니다.
APP_TITLE=OpenAI Music Recommendation Chatbot

# 개발 중에는 true로 설정합니다.
DEBUG=true
